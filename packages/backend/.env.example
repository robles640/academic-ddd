# Entorno (development | production)
NODE_ENV=development

# Servidor API
PORT=3000

# JWT (cambiar SIEMPRE en producción por un secreto seguro, largo y aleatorio)
JWT_SECRET=change_me_in_production_please_123456789

# TypeORM / PostgreSQL (usado por la app y por el CLI de migraciones)
TYPEORM_HOST=localhost
TYPEORM_PORT=5432
TYPEORM_USERNAME=postgres
TYPEORM_PASSWORD=postgres
TYPEORM_DATABASE=academic

STUDENT_DEFAULT_PASSWORD=TempStudent1!

# CORS (lista separada por comas de orígenes permitidos, por ejemplo: http://localhost:5173,https://mi-frontend.com)
CORS_ORIGIN=http://localhost:5173

# Cookie del JWT (HTTPOnly). Debe coincidir con lo usado por JwtStrategy.
JWT_COOKIE_NAME=access_token
# Dominio usado para la cookie (opcional). Ejemplo para permitir subdominios: .academic.omarmus.com
COOKIE_DOMAIN=
# SameSite de la cookie. Opciones: lax | strict | none
# Caso cross-domain (frontend y backend en dominios diferentes): usa `none`
COOKIE_SAMESITE=lax
# Obliga el flag `secure` de la cookie (opcional). Ejemplos: true | false
# Si no se define, se usa req.secure (y si COOKIE_SAMESITE=none, se fuerza a true).
COOKIE_SECURE=